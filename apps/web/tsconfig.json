{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "baseUrl": "./",
    "allowJs": false,
    "strict": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "paths": {
      "@components/*": ["src/components/*"],
      "@pages/*": ["src/pages/*"],
      "@api/*": ["src/api/*"],
      "@useHooks/*": ["src/api/hooks/*"],
      "@assets/*": ["src/assets/*"]
    }
  },
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS" // ts-node는 CJS로 실행
    }
  },
  "include": ["src", "global.d.ts"]
}
