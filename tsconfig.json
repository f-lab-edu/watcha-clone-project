{
  "compilerOptions": {
    "target": "ES6",
    "module": "ESNext",
    "allowJs": false,
    "strict": true,
    "jsx": "react-jsx",
    "noImplicitAny": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "bundler",
    "outDir": "./dist"
  }
}
